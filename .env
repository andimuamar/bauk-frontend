# URL API menu WordPress (plugin custom-menu-api).
# Salin file ini menjadi .env.local lalu sesuaikan bila perlu.
WP_MENU_API_URL=https://bauk.uis.ac.id/wp-json/custom-menu-api/v1/menus/location/primary

# Base URL WordPress untuk REST API standar (wp/v2/posts, wp/v2/pages, wp/v2/categories).
WP_BASE_URL=https://bauk.uis.ac.id
